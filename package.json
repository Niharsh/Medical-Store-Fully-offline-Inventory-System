{
  "name": "choudhary-medical-store",
  "version": "1.0.0",
  "description": "Desktop billing software for Choudhary Medical Store",
  "main": "electron/main.js",
  "homepage": "./",
  "author": "Choudhary Medical Store",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"cd frontend && npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "build": "cd frontend && npm run build",
    "test": "cd frontend && npm run test",
    "electron-builder": "npm run build && electron-builder",
    "electron-build": "npm run build && electron-builder -w",
    "dist": "npm run build && electron-builder",
    "dist:portable": "npm run build && electron-builder -p never",
    "pack": "electron-builder --dir",
    "prestart": "npm run build"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^27.3.11",
    "electron-builder": "^24.9.1",
    "electron-rebuild": "^3.2.9",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.choudharymedical.billing",
    "productName": "Choudhary Medical Store",
    "directories": {
      "buildResources": "frontend/public",
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "frontend/dist/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "certificateFile": null,
      "certificatePassword": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Choudhary Medical Store"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.exe"
    }
  },
  "dependencies": {
    "better-sqlite3": "^8.7.0"
  }
}
